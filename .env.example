# Twitter/X credentials — only needed for Twitter scraping
# Use a throwaway / burner account to avoid risk to your main account
# Session cookies (required by the scraper — grab from browser devtools while logged in)
TWITTER_AUTH_TOKEN=your_auth_token_cookie
TWITTER_CT0=your_ct0_cookie
TWITTER_USERNAME=your_x_username
TWITTER_PASSWORD=your_x_password
TWITTER_EMAIL=your_x_email@example.com
TWITTER_EMAIL_PASSWORD=your_email_password   # password for the email above
